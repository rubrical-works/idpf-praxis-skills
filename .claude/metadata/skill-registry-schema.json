{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "skill-registry-schema.json",
  "title": "Skill Registry Schema",
  "description": "Schema for .claude/metadata/skill-registry.json — generated by build-skill-registry.js from SKILL.md frontmatter",
  "type": "object",
  "required": [
    "generatedAt",
    "version",
    "skillCount",
    "skills"
  ],
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of generation"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version"
    },
    "skillCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of skills in registry"
    },
    "skills": {
      "type": "array",
      "description": "Skill entries extracted from SKILL.md frontmatter",
      "items": {
        "type": "object",
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Skill package name (directory name)"
          },
          "description": {
            "type": "string",
            "description": "Skill description from frontmatter"
          },
          "triggers": {
            "type": "array",
            "description": "Trigger patterns for auto-invocation",
            "items": {
              "type": "string"
            }
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Skill version"
          },
          "frameworkCompatibility": {
            "type": "string",
            "description": "Minimum framework version (e.g., >=0.60.0)"
          },
          "lastUpdated": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Last update date"
          },
          "checksum": {
            "type": [
              "string",
              "null"
            ],
            "description": "SHA-256 checksum of the skill package (null if no package)"
          },
          "category": {
            "type": "string",
            "description": "Skill category (e.g., code-quality, architecture, testing)"
          },
          "suggests": {
            "type": "array",
            "description": "Suggested related skills",
            "items": {
              "type": "string"
            }
          },
          "postInstall": {
            "type": "string",
            "description": "Post-install instructions"
          },
          "relevantTechStack": {
            "type": "array",
            "description": "Technology keywords this skill applies to",
            "items": {
              "type": "string"
            }
          },
          "invocationMode": {
            "type": "string",
            "enum": [
              "auto",
              "manual",
              "direct-only"
            ],
            "description": "How the skill is invoked"
          },
          "defaultSkill": {
            "type": "boolean",
            "description": "Whether this is a default skill for all projects"
          },
          "copyright": {
            "type": "string",
            "description": "Copyright notice"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
