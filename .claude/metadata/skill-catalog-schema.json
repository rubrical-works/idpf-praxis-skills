{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "skill-catalog-schema.json",
  "title": "Skill Catalog Schema",
  "description": "Schema for .claude/metadata/skill-catalog.json — generated by build-skill-catalog.js with download URLs and file sizes",
  "type": "object",
  "required": [
    "catalogVersion",
    "frameworkVersion",
    "generatedAt",
    "baseUrl",
    "skillCount",
    "skills"
  ],
  "properties": {
    "catalogVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Catalog format version"
    },
    "frameworkVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Framework version this catalog was built for"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of generation"
    },
    "baseUrl": {
      "type": "string",
      "format": "uri",
      "description": "Base URL for downloading skill packages from GitHub releases"
    },
    "skillCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of skills in catalog"
    },
    "skills": {
      "type": "array",
      "description": "Skill entries with download metadata",
      "items": {
        "type": "object",
        "required": [
          "name",
          "version",
          "description",
          "checksum",
          "size",
          "assetFilename"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Skill package name"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Skill version"
          },
          "frameworkCompatibility": {
            "type": "string",
            "description": "Minimum framework version"
          },
          "category": {
            "type": "string",
            "description": "Skill category"
          },
          "description": {
            "type": "string",
            "description": "Skill description"
          },
          "relevantTechStack": {
            "type": "array",
            "description": "Technology keywords",
            "items": {
              "type": "string"
            }
          },
          "invocationMode": {
            "type": "string",
            "enum": [
              "auto",
              "manual",
              "direct-only"
            ],
            "description": "How the skill is invoked"
          },
          "checksum": {
            "type": [
              "string",
              "null"
            ],
            "description": "SHA-256 checksum of the zip package"
          },
          "size": {
            "type": "integer",
            "minimum": 0,
            "description": "File size in bytes"
          },
          "lastUpdated": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Last update date"
          },
          "assetFilename": {
            "type": "string",
            "pattern": "\\.zip$",
            "description": "Zip filename for download"
          },
          "defaultSkill": {
            "type": "boolean",
            "description": "Whether this is a default skill"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
