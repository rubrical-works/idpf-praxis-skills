{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "skill-keywords-schema.json",
  "title": "Skill Keywords Schema",
  "description": "Schema for .claude/metadata/skill-keywords.json — keyword-to-skill mappings for /create-backlog and /add-story",
  "type": "object",
  "required": [
    "version",
    "description",
    "defaultSkills",
    "skillKeywords"
  ],
  "properties": {
    "generatedAt": {
      "type": "string",
      "description": "Generation timestamp"
    },
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description"
    },
    "defaultSkills": {
      "type": "array",
      "description": "Skills included by default for all projects",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "skillKeywords": {
      "type": "object",
      "description": "Skill name to keyword array mapping",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "groupKeywords": {
      "type": "object",
      "description": "Group name to keyword array mapping for multi-skill suggestions",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "skillCategories": {
      "type": "object",
      "description": "Map of skill-name to category string for display grouping",
      "additionalProperties": {
        "type": "string"
      }
    },
    "_schema": {
      "type": "object",
      "description": "Schema documentation for the fields in this file"
    }
  },
  "additionalProperties": false
}
