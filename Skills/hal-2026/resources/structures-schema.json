{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "structures-schema.json",
  "title": "Data Structure Reference",
  "description": "Schema for the HAL-2026 data structure families reference.",
  "type": "object",
  "required": ["$schema", "description", "usage", "families", "crossStructureDecisionGuide"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "structures-schema.json"
    },
    "description": {
      "type": "string"
    },
    "usage": {
      "type": "string"
    },
    "families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/structureFamily"
      }
    },
    "crossStructureDecisionGuide": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/decisionGuideEntry"
      }
    }
  },
  "definitions": {
    "structureFamily": {
      "type": "object",
      "required": ["id", "name", "coreContract", "whenToPrefer", "variants", "implementationTraps", "disqualifiers"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": {
          "type": "string"
        },
        "coreContract": {
          "type": "string"
        },
        "whenToPrefer": {
          "type": "array",
          "items": { "type": "string" }
        },
        "variants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/variant"
          }
        },
        "implicitGraphPatterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional. Used by graph-representations family for implicit graph patterns."
        },
        "implementationTraps": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "disqualifiers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "variant": {
      "type": "object",
      "required": ["name", "characteristic", "bestUsedWhen"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "characteristic": {
          "type": "string"
        },
        "bestUsedWhen": {
          "type": "string"
        }
      }
    },
    "decisionGuideEntry": {
      "type": "object",
      "required": ["bottleneckOperation", "reachFor"],
      "additionalProperties": false,
      "properties": {
        "bottleneckOperation": {
          "type": "string"
        },
        "reachFor": {
          "type": "string"
        }
      }
    }
  }
}
