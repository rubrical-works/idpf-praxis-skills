{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Context Map",
  "description": "Maps problem domain keywords to skills for context gathering in engage-exocortex Step 0",
  "type": "object",
  "required": ["description", "maxSkillsPerInvocation", "skills", "domainSkipKeywords"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "description": { "type": "string" },
    "maxSkillsPerInvocation": { "type": "integer", "minimum": 1, "maximum": 5 },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "keywords", "provides", "priority", "requiresCodebase"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "type": { "type": "string", "enum": ["injector", "invokable", "reference", "educational"] },
          "keywords": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "provides": { "type": "string" },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] },
          "requiresCodebase": { "type": "boolean" }
        }
      }
    },
    "domainSkipKeywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "If problem contains these keywords, skip Step 0 entirely (algorithmic-only)"
    }
  }
}
