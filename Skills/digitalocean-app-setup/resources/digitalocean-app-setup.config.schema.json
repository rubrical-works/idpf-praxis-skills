{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "digitalocean-app-setup.config.schema.json",
  "title": "digitalocean-app-setup configuration",
  "type": "object",
  "required": ["version", "cli", "appCommands", "githubAction", "secrets", "specFiles"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "_description": { "type": "string" },
    "version": { "type": "string" },
    "cli": {
      "type": "object",
      "required": ["name", "install", "auth"],
      "properties": {
        "name": { "type": "string" },
        "install": {
          "type": "object",
          "required": ["macos", "linux", "windows"],
          "additionalProperties": { "type": "string" }
        },
        "auth": {
          "type": "object",
          "required": ["command", "envVar"],
          "properties": {
            "command": { "type": "string" },
            "envVar": { "type": "string" }
          }
        }
      }
    },
    "appCommands": {
      "type": "object",
      "required": ["create", "createDeployment", "logs"],
      "additionalProperties": { "type": "string" }
    },
    "githubAction": {
      "type": "object",
      "required": ["uses", "tokenInput"],
      "additionalProperties": true,
      "properties": {
        "uses": { "type": "string", "pattern": "@" },
        "tokenInput": { "type": "string" }
      }
    },
    "secrets": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "source", "description"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "source": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "httpPort": { "type": "integer" }
      }
    },
    "specFiles": {
      "type": "object",
      "required": ["appSpec"],
      "additionalProperties": { "type": "string" }
    }
  }
}
