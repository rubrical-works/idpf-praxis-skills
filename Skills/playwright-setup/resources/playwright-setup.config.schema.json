{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "playwright-setup.config.schema.json",
  "type": "object",
  "required": ["version", "prerequisites", "install", "verify", "browsers", "browserCacheLocations", "ci"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "_description": { "type": "string" },
    "version": { "type": "string" },
    "prerequisites": {
      "type": "object",
      "required": ["nodeMinimumMajor"],
      "additionalProperties": true,
      "properties": {
        "nodeMinimumMajor": { "type": "integer", "minimum": 1 }
      }
    },
    "install": {
      "type": "object",
      "required": ["package", "installPackageCommand", "installBrowsersCommand", "installSystemDepsCommand", "installWithDepsCommand"],
      "additionalProperties": { "type": "string" }
    },
    "verify": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "browsers": {
      "type": "array",
      "items": { "type": "string", "enum": ["chromium", "firefox", "webkit"] },
      "minItems": 1
    },
    "browserCacheLocations": {
      "type": "object",
      "required": ["windows", "macos", "linux"],
      "additionalProperties": { "type": "string" }
    },
    "ci": {
      "type": "object",
      "required": ["dockerImage", "githubActions"],
      "additionalProperties": true,
      "properties": {
        "dockerImage": { "type": "string" },
        "githubActions": {
          "type": "object",
          "required": ["checkout", "setupNode", "uploadArtifact"],
          "additionalProperties": true
        }
      }
    },
    "specFiles": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
