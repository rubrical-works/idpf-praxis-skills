{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "render-project-setup.config.schema.json",
  "type": "object",
  "required": ["version", "api", "secrets", "specFiles"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "_description": { "type": "string" },
    "version": { "type": "string" },
    "cli": {
      "type": "object",
      "required": ["name", "installCommand"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "installCommand": { "type": "string" }
      }
    },
    "api": {
      "type": "object",
      "required": ["baseUrl", "deployTriggerEndpoint", "deployTriggerCommand"],
      "additionalProperties": false,
      "properties": {
        "baseUrl": { "type": "string", "pattern": "^https://" },
        "deployTriggerEndpoint": { "type": "string", "pattern": "^/" },
        "deployTriggerCommand": { "type": "string" }
      }
    },
    "secrets": {
      "type": "object",
      "required": ["required"],
      "additionalProperties": true,
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "source", "description"]
          }
        },
        "vars": { "type": "array" }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "httpPort": { "type": "integer" } }
    },
    "previewUrlPattern": { "type": "string" },
    "specFiles": {
      "type": "object",
      "required": ["blueprint"],
      "additionalProperties": { "type": "string" }
    }
  }
}
